# --- Exchange (opsional saat DRY_RUN=true) ---
EXCHANGE_API_KEY=
EXCHANGE_SECRET=

# --- LLM (dipakai evaluator saja, bukan bot loop) ---
# LLM_PROVIDER=api          -> @anthropic-ai/sdk, butuh ANTHROPIC_API_KEY, schema dijamin
# LLM_PROVIDER=claude-code  -> shell out ke `claude` CLI, pakai login subscription, tanpa API key
# Kosong = auto: api kalau ANTHROPIC_API_KEY diisi, selain itu claude-code.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
# Opsional: arahkan ke endpoint Anthropic-compatible lain (proxy lokal, dst).
# ANTHROPIC_BASE_URL=http://localhost:20128/v1
# Opsional: timpa model default (claude-opus-4-8) — pakai kalau gateway cuma
# punya credential untuk model/alias tertentu.
# LLM_MODEL=daily-code

# --- Grid ---
SYMBOL=ETH/USDT
GRID_UPPER=4200
GRID_LOWER=2800
GRID_STEP=100
USDT_PER_LEVEL=100
# Berapa level kosong di bawah harga yang dipasangi bid sekaligus.
# 1 = bid tunggal (harga yang gap turun akan melewati level tanpa terisi).
MAX_OPEN_BIDS=3

# --- Runtime ---
POLL_INTERVAL_MS=60000
TIMEFRAME=1h

# --- Circuit breaker (safety cutout, BUKAN stop loss) ---
# Halt entry baru + cancel bid nongkrong saat bahaya. Lot existing tetap dipegang,
# sell tetap jalan. Sekali trip harus reset manual: bun run reset-breaker
#
# Kerugian unrealized (mark-to-market) semua lot terbuka melebihi X USDT -> trip.
# Ini risiko utama grid no-cutloss. 0 = mati. Isi sesuai modal, mis. 50% total risiko.
MAX_DRAWDOWN_USDT=0
# N tick gagal beruntun (exchange mati/auth rusak) -> trip. 0 = mati.
MAX_CONSECUTIVE_ERRORS=5
# Harga lompat > X% dibanding tick sebelumnya -> skip tick itu (feed glitch guard).
# Bukan latch. 0 = mati. Contoh: 15.
MAX_PRICE_JUMP_PCT=0

# --- Safety ---
# DRY_RUN=true  -> tidak ada order dikirim, fill disimulasikan
# TESTNET=true  -> ccxt sandbox mode
DRY_RUN=true
TESTNET=true
# Wajib diisi persis seperti ini kalau DRY_RUN=false DAN TESTNET=false:
# LIVE_CONFIRM=i-understand-the-risk
